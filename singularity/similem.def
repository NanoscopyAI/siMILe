Bootstrap: docker
From: ubuntu

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/miniconda3/bin:$PATH

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get -y update
    apt-get update && apt-get install -y automake build-essential bzip2 wget git default-jre unzip

    wget https://repo.continuum.io/miniconda/Miniconda3-latest-Linux-x86_64.sh
    bash Miniconda3-latest-Linux-x86_64.sh -b -f -p /miniconda3/
    rm Miniconda3-latest-Linux-x86_64.sh
    export PATH="/miniconda3/bin:$PATH"

    conda install -y python=3.9  # Updated Python version
    conda install -y -c conda-forge pip 'numpy<2' scikit-learn configparser pandas joblib
    pip install tensorflow==2.7.1 protobuf==3.20.*

